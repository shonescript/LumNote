<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarkdownEditor.Controls"
        xmlns:vm="clr-namespace:MarkdownEditor.ViewModels"
        xmlns:conv="clr-namespace:MarkdownEditor.Converters"
        xmlns:core="clr-namespace:MarkdownEditor.Core"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="MarkdownEditor.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="True"
        Title="LumNote"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="32"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        >

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource ButtonPressedBackground}"/>
    </Style>

    <!-- Tab 样式，模拟 VSCode 顶部标签 -->
    <Style Selector="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="TabItem">
      <Setter Property="Foreground" Value="{DynamicResource TabItemForeground}"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Normal"/>
      <Setter Property="MinHeight" Value="28"/>
    </Style>
    <Style Selector="TabItem /template/ Border">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="TabItem:pointerover:not(:selected) /template/ Border">
      <Setter Property="Background" Value="{DynamicResource TabItemHoverBackground}"/>
    </Style>
    <Style Selector="TabItem:selected /template/ Border">
      <Setter Property="Background" Value="{DynamicResource TabItemSelectedBackground}"/>
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="{DynamicResource TabItemSelectedForeground}"/>
      <Setter Property="FontWeight" Value="Normal"/>
    </Style>
    <Style Selector="TabItem:selected:pointerover /template/ Border">
      <Setter Property="Background" Value="{DynamicResource TabItemSelectedBackground}"/>
    </Style>
    <!-- 去掉 Avalonia Fluent 默认的下划线：隐藏 PART_SelectedPipe -->
    <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Height" Value="0"/>
    </Style>
    <!-- 隐藏 TabControl 默认内容区域，只保留标签头 -->
    <Style Selector="TabControl ContentPresenter#PART_SelectedContentHost">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Height" Value="0"/>
    </Style>
    <Style Selector="Button.active">
      <Setter Property="Background" Value="{DynamicResource TitleBarBackground}"/>
    </Style>
    <!-- 标签页关闭按钮：默认隐藏，悬停或选中时显示 -->
    <Style Selector="TabItem Button.tab-close">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource TabItemForeground}"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TabItem:pointerover Button.tab-close">
      <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="TabItem:selected Button.tab-close">
      <Setter Property="IsVisible" Value="True"/>
    </Style>

    <Style Selector="GridSplitter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SplitterBorderBrush}"/>
      <Setter Property="Width" Value="2"/>
      <Setter Property="Cursor" Value="SizeWestEast"/>
    </Style>
    <Style Selector="GridSplitter:pointerover, GridSplitter:pressed">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="BorderBrush" Value="{DynamicResource StatusBarBackground}"/>
    </Style>
    <Style Selector="Border.sidebar">
      <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
    </Style>
    <Style Selector="Border.sidebarHeader">
      <Setter Property="Background" Value="{DynamicResource SidebarHeaderBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
    </Style>
    <Style Selector="ScrollViewer.settingsPane">
      <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
    </Style>
    <Style Selector="Border.welcomePage">
      <Setter Property="Background" Value="{DynamicResource WelcomePageBackground}"/>
    </Style>
    <Style Selector="Border.titleBar">
      <Setter Property="Background" Value="{DynamicResource TitleBarBackground}"/>
    </Style>
    <Style Selector="Border.titleBar TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TitleBarForeground}"/>
    </Style>
    <Style Selector="Border.gitPane">
      <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
    </Style>
    <Style Selector="Border.searchPane, Border.gitPane">
      <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
    </Style>
    <Style Selector="Border.gitPane TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource SidebarTextForeground}"/>
    </Style>
    <Style Selector="Border.welcomePage TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource WelcomePageTextForeground}"/>
    </Style>
    <Style Selector="ScrollViewer.settingsPane TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource SidebarTextForeground}"/>
    </Style>
    <Style Selector="Border.sidebar TreeView">
      <Setter Property="Foreground" Value="{DynamicResource SidebarTextForeground}"/>
    </Style>
    <Style Selector="Border.sidebar ListBox">
      <Setter Property="Foreground" Value="{DynamicResource SidebarTextForeground}"/>
    </Style>
    <Style Selector="Border.explorerHeader">
      <Setter Property="Background" Value="{DynamicResource ExplorerHeaderBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SidebarBorderBrush}"/>
    </Style>
    <Style Selector="Border.explorerHeader TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource ExplorerHeaderForeground}"/>
    </Style>
    <Style Selector="Border.searchPane TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TitleBarForeground}"/>
    </Style>
    <Style Selector="Border.searchPane TextBox, Border.searchPane ComboBox">
      <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
      <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
    </Style>
    <Style Selector="Border.welcomePage Button">
      <Setter Property="Foreground" Value="{DynamicResource WelcomePageLinkForeground}"/>
    </Style>
    <!-- 编辑区背景跟随界面主题 -->
    <Style Selector="Grid.editorPane">
      <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
    </Style>
    <!-- 预览区背景交给 Markdown 渲染引擎控制，这里保持透明 -->
    <Style Selector="Grid.previewPane">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.tabBarBorder">
      <Setter Property="Background" Value="{DynamicResource TabBarBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource TabBarBorderBrush}"/>
    </Style>
    <Style Selector="ae|TextEditor.editorControl">
      <Setter Property="Background" Value="{DynamicResource ContentBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource EditorForeground}"/>
    </Style>
    <Style Selector="Border.statusBar">
      <Setter Property="Background" Value="{DynamicResource StatusBarBackground}"/>
    </Style>
    <Style Selector="Border.statusBar TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource StatusBarForeground}"/>
    </Style>
    <Style Selector="Border.statusBar Button">
      <Setter Property="Foreground" Value="{DynamicResource StatusBarForeground}"/>
    </Style>
    <!-- 预览控件背景由 Markdown 渲染主题控制，这里不再用界面主题色覆盖，避免冲掉 Markdown 背景 -->
    <Style Selector="controls|MarkdownEngineView ScrollViewer">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Window.Styles>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
  </Window.KeyBindings>

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- 顶部：标题 + 菜单（VSCode 风格标题栏，可拖动、双击最大化，支持 Windows 停靠） -->
    <Border Grid.Row="0" Padding="8,0" Classes="titleBar">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto" Height="32">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,12,0">
          <Image Source="avares://MarkdownEditor/asserts/icon.ico" Width="16" Height="16" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding TitleStatus}"
                     Margin="6,0,0,0"
                     VerticalAlignment="Center"
                     FontSize="13"
                     FontWeight="SemiBold"/>
        </StackPanel>

        <Menu Grid.Column="1" VerticalAlignment="Stretch">
          <MenuItem Header="文件(_F)">
            <MenuItem Header="新建" x:Name="NewFileMenuItem"/>
            <MenuItem Header="打开文件夹..." x:Name="OpenFolderMenuItem"/>
            <MenuItem Header="添加文件夹..." x:Name="AddFoldersMenuItem"/>
            <MenuItem Header="打开文件..." x:Name="OpenFileMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="保存工作区..." x:Name="SaveWorkspaceMenuItem"/>
            <MenuItem Header="打开工作区..." x:Name="OpenWorkspaceMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="保存" x:Name="SaveMenuItem" HotKey="Ctrl+S"/>
            <MenuItem Header="另存为..." x:Name="SaveAsMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="导出" x:Name="ExportMenu">
              <MenuItem Header="导出为 HTML..." x:Name="ExportHtmlMenuItem"/>
              <MenuItem Header="导出为 PDF..." x:Name="ExportPdfMenuItem"/>
              <MenuItem Header="导出为长图 (PNG)..." x:Name="ExportPngMenuItem"/>
            </MenuItem>
            <MenuItem Header="-"/>
            <MenuItem Header="关闭当前文档" x:Name="CloseEditorMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="退出" x:Name="ExitMenuItem"/>
          </MenuItem>
          <MenuItem Header="帮助(_H)">
            <MenuItem Header="关于" x:Name="AboutMenuItem"/>
          </MenuItem>
        </Menu>

        <Border Grid.Column="2"
                x:Name="TitleDragArea"
                Background="Transparent">
          <TextBlock Text="{Binding CenterTitle}"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="320"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="13"
                     IsHitTestVisible="False"/>
        </Border>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="8"/>
      </Grid>
    </Border>

    <!-- 主体：侧栏 + 右侧内容区；折叠条悬浮在顶层不占宽度 -->
    <Grid Grid.Row="1" x:Name="MainAreaGrid">
      <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" MinWidth="180" MaxWidth="420"/>
          <ColumnDefinition Width="4"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧栏：仅内容区（折叠条移至悬浮层） -->
        <Border Grid.Column="0"
                x:Name="SidebarBorder"
                BorderThickness="0,0,1,0"
                Classes="sidebar">
          <Grid x:Name="SidebarInnerGrid" ColumnDefinitions="*">
            <Grid Grid.Column="0" x:Name="SidebarContentGrid" RowDefinitions="Auto,*">
          <!-- 顶部活动栏（水平，与文档标签栏高度统一：28px） -->
          <Border Grid.Row="0"
                  BorderThickness="0,0,0,1"
                  Padding="2,2"
                  MinHeight="32"
                  Classes="sidebarHeader">
            <StackPanel Orientation="Horizontal" Spacing="2"
                        VerticalAlignment="Center">
              <Button x:Name="ActivityExplorerButton"
                      ToolTip.Tip="资源管理器"
                      Width="32" Height="30"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <Image Source="avares://MarkdownEditor/asserts/file_explorer.png"
                       Width="16" Height="16"/>
              </Button>
              <Button x:Name="ActivitySearchButton"
                      ToolTip.Tip="搜索"
                      Width="32" Height="30"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <Image Source="avares://MarkdownEditor/asserts/search.png"
                       Width="16" Height="16"/>
              </Button>
              <Button x:Name="ActivityGitButton"
                      ToolTip.Tip="版本管理 (Git)"
                      Width="32" Height="30"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <Image Source="avares://MarkdownEditor/asserts/version_control.png"
                       Width="16" Height="16"/>
              </Button>
              <Button x:Name="ActivitySettingsButton"
                      ToolTip.Tip="设置"
                      Width="32" Height="30"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Content="⚙"
                      FontSize="16"/>
            </StackPanel>
          </Border>

          <Grid Grid.Row="1">
            <!-- 资源管理器 -->
            <Grid IsVisible="{Binding ShowExplorerPane}" RowDefinitions="Auto,*">
              <!-- 根目录行：路径/名称 + 刷新 -->
              <Border Grid.Row="0" Padding="6,4" BorderThickness="0,0,0,1" Classes="explorerHeader">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <TextBlock Text="{Binding DocumentFolder}"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             MaxWidth="120"
                             ToolTip.Tip="{Binding DocumentFolder}"/>
                  <Button x:Name="FileTreeRefreshRootBtn"
                          ToolTip.Tip="刷新"
                          Width="22" Height="22"
                          Padding="0"
                          FontSize="11"
                          Content="↻"/>
                </StackPanel>
              </Border>
            <Grid Grid.Row="1" RowDefinitions="*">
              <!-- 无工作区时居中显示两个按钮 -->
              <StackPanel IsVisible="{Binding ShowWorkspacePlaceholder}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Spacing="12">
                <Button x:Name="ExplorerOpenWorkspaceBtn"
                        Content="打开工作区"
                        MinWidth="120"
                        Padding="12,8"/>
                <Button x:Name="ExplorerOpenFolderBtn"
                        Content="打开文件夹"
                        MinWidth="120"
                        Padding="12,8"/>
              </StackPanel>
              <!-- 自定义扁平 + 虚拟化列表模拟文件树，整行点击展开/折叠（VSCode 风格），避免 TreeView 缩进/对齐问题 -->
              <ListBox Grid.Row="0"
                       x:Name="FileTreeList"
                       IsVisible="{Binding HasWorkspaceOpen}"
                       ItemsSource="{Binding VisibleFileTree}"
                       SelectedItem="{Binding SelectedTreeNode}"
                       Margin="4,0,4,4"
                       Padding="0"
                       Background="Transparent"
                       BorderThickness="0"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ContextFlyout>
                  <MenuFlyout>
                    <MenuItem Header="打开所在文件夹" x:Name="FileTreeOpenFolderItem"/>
                    <MenuItem Header="复制路径" x:Name="FileTreeCopyPathItem"/>
                    <MenuItem Header="重命名" x:Name="FileTreeRenameItem"/>
                    <MenuItem Header="新建文件" x:Name="FileTreeNewFileItem"/>
                    <MenuItem Header="新建文件夹" x:Name="FileTreeNewFolderItem"/>
                    <MenuItem Header="删除" x:Name="FileTreeDeleteItem"/>
                  </MenuFlyout>
                </ListBox.ContextFlyout>
                <ListBox.Styles>
                  <Style Selector="ListBoxItem" x:DataType="vm:FileTreeNode">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="18"/>
                  </Style>
                  <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedBackground}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ListBoxItemSelectedForeground}"/>
                  </Style>
                  <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                  </Style>
                </ListBox.Styles>
                <!-- 普通 StackPanel 避免虚拟化回收导致的展开/折叠闪烁 -->
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel/>
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:FileTreeNode">
                    <StackPanel Orientation="Horizontal"
                                Spacing="1"
                                Margin="2,0,2,0"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{Binding FullPath}"
                                Background="Transparent">
                      <!-- 缩进：固定宽度占位，Level 决定层级（根下一级=12px，再下一级=24px…） -->
                      <Border Width="{Binding Converter={x:Static conv:LevelToIndentWidthConverter.Instance}}"
                              MinWidth="0"
                              Background="Transparent"/>
                      <!-- 箭头列：固定宽度 -->
                      <Grid Width="12"
                            Margin="0,0,2,0"
                            VerticalAlignment="Center">
                        <Image Source="avares://MarkdownEditor/asserts/folder_arrow_right_dark.png"
                               Width="10"
                               Height="10"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ShowRightArrow}"/>
                        <Image Source="avares://MarkdownEditor/asserts/folder_arrow_down_dark.png"
                               Width="10"
                               Height="10"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ShowDownArrow}"/>
                      </Grid>
                      <!-- 图标列 -->
                      <TextBlock Text="{Binding IconText}"
                                 Width="12"
                                 FontSize="12"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                      <!-- 名称 / 重命名 -->
                      <TextBlock Text="{Binding DisplayName}"
                                 VerticalAlignment="Center"
                                 FontSize="12"
                                 TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding ShowLabel}"/>
                      <TextBox Text="{Binding EditName, Mode=TwoWay}"
                               IsVisible="{Binding IsRenaming}"
                               MinWidth="80"
                               Height="22"
                               FontSize="12"
                               Padding="4,0,4,0"
                               VerticalContentAlignment="Center"
                               Loaded="TreeItemRenameTextBox_OnLoaded"
                               LostFocus="TreeItemRename_OnLostFocus"
                               BorderThickness="1"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>

          <!-- 搜索（跨文档，点击结果定位到行；扁平列表 + 虚拟化以降低内存与 UI 阻塞） -->
          <Border x:Name="SearchPaneBorder"
                  IsVisible="{Binding ShowSearchPane}"
                  Padding="8,6"
                  Classes="searchPane">
            <Grid RowDefinitions="Auto,Auto,*">
              <Grid.DataTemplates>
                <DataTemplate x:DataType="vm:SearchResultGroupRowViewModel">
                  <StackPanel Margin="0,1">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="0,3,8,3"
                            HorizontalContentAlignment="Left"
                            Click="SearchResultFileHeader_OnClick">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Width="14" Height="14"
                                VerticalAlignment="Center"
                                Background="Transparent">
                          <TextBlock Text="{Binding ExpandArrow}"
                                     FontSize="11"
                                     FontFamily="Segoe UI Symbol,Consolas,sans-serif"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Vertical" Spacing="0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding FileName}"
                                     FontSize="12"
                                     TextTrimming="CharacterEllipsis"
                                     Foreground="#3794ff"/>
                          <TextBlock Text="{Binding FolderPath}"
                                     FontSize="10"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding HasFolderPath}"
                                     Foreground="{DynamicResource EditorForeground}"/>
                        </StackPanel>
                      </StackPanel>
                    </Button>
                  </StackPanel>
                </DataTemplate>
                <DataTemplate x:DataType="vm:SearchResultLineRowViewModel">
                  <Button Background="Transparent"
                          BorderThickness="0"
                          Padding="0,2,0,2"
                          HorizontalContentAlignment="Left"
                          IsVisible="{Binding IsVisible}"
                          Click="SearchResultLine_OnClick"
                          Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding LineNumber, StringFormat=L{0}}"
                                 FontSize="11"
                                 VerticalAlignment="Center"
                                 MinWidth="28"
                                 FontFamily="Consolas,Segoe UI,sans-serif"
                                 Foreground="{DynamicResource EditorForeground}"/>
                      <TextBlock Text="{Binding LinePreview}"
                                 FontSize="11"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 FontFamily="Consolas,Segoe UI,sans-serif"
                                 Foreground="{DynamicResource EditorForeground}"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </Grid.DataTemplates>
              <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="搜索" FontWeight="SemiBold" FontSize="12"/>
                <TextBox x:Name="SearchQueryTextBox"
                         Text="{Binding SearchQuery}"
                         Watermark="搜索文档..."
                         FontSize="12"
                         Padding="6,4"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,4,0,2">
                <TextBlock Text="结果（按文件分组，点击行定位）"
                           FontSize="10"
                           VerticalAlignment="Center"/>
                <Button x:Name="SearchStopButton"
                        Command="{Binding CancelSearchCommand}"
                        IsVisible="{Binding IsSearching}"
                        Padding="4,2"
                        FontSize="10"
                        Content="停止"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SearchResultStatusText}"
                           FontSize="10"
                           Foreground="{DynamicResource EditorForeground}"
                           VerticalAlignment="Center"
                           Opacity="0.85"/>
              </StackPanel>
              <ScrollViewer Grid.Row="2"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            MinHeight="0">
                <ItemsControl x:Name="SearchResultGroupsControl"
                              ItemsSource="{Binding FlatSearchResultRows}"
                              Background="Transparent"
                              FontFamily="Consolas,Segoe UI,sans-serif">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <ContentPresenter Content="{Binding}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>

          <!-- Git -->
          <Border IsVisible="{Binding ShowGitPane}"
                  Padding="12"
                  Classes="gitPane">
            <StackPanel Spacing="8">
              <TextBlock Text="版本管理" FontWeight="Bold"/>
              <TextBlock Text="版本管理"
                         FontSize="11"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- 设置 -->
          <ScrollViewer IsVisible="{Binding ShowSettingsPane}"
                        Padding="12"
                        Classes="settingsPane">
            <StackPanel Spacing="12">
              <TextBlock Text="设置" FontWeight="Bold"/>
              <TextBlock Text="界面" FontSize="11"/>
              <StackPanel Spacing="6">
                <TextBlock Text="界面主题" FontSize="11"/>
                <ComboBox x:Name="ThemeComboBox"
                          ItemsSource="{Binding ThemeDisplayNames}"
                          SelectedItem="{Binding CurrentThemeDisplayName, Mode=TwoWay}"
                          MinWidth="120"
                          HorizontalAlignment="Left"/>
              <TextBlock Text="渲染区主题（Markdown 样式）" FontSize="11"/>
                <ComboBox x:Name="PresetComboBox"
                          ItemsSource="{Binding Config.StylePresets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                          MinWidth="120"
                          HorizontalAlignment="Left">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="core:MarkdownStylePreset">
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            </StackPanel>
          </ScrollViewer>
          </Grid>
        </Grid>
        </Grid>
      </Border>

      <!-- 侧栏分隔条：拖动时只显示蓝色预览线，松手后再应用布局（VS 风格） -->
      <Border x:Name="SidebarSplitter"
              Grid.Column="1"
              Background="Transparent"
              BorderBrush="{DynamicResource SplitterBorderBrush}"
              BorderThickness="1,0,0,0"
              Width="4"
              Cursor="SizeWestEast"/>
      <Border x:Name="SidebarSplitterOverlay"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Grid.Row="0"
              Background="Transparent"
              IsHitTestVisible="False"
              ZIndex="10">
        <Border x:Name="SidebarSplitterPreviewLine"
                Width="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Background="{DynamicResource StatusBarBackground}"
                IsVisible="False"/>
      </Border>

      <!-- 右侧内容区：欢迎页 或 文档标签页+编辑+预览 -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*">
        <!-- 欢迎页：无打开文档时显示，VSCode 风格最近打开 -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowWelcomeView}"
                Padding="24,32"
                Classes="welcomePage">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="560" HorizontalAlignment="Left">
              <TextBlock Text="打开最近"
                         FontSize="18"
                         FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="WelcomeOpenFileButton"
                        Content="打开文件..."
                        FontSize="12"
                        Padding="12,6"/>
                <Button x:Name="WelcomeOpenFolderButton"
                        Content="打开文件夹..."
                        FontSize="12"
                        Padding="12,6"/>
              </StackPanel>
              <StackPanel Spacing="2">
                <TextBlock Text="最近打开的文档（按打开时间排序）"
                           FontSize="11"
                           Margin="0,4,0,0"/>
                <ItemsControl ItemsSource="{Binding RecentFileItemsVisible}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RecentFileItem">
                      <Button Background="Transparent"
                              Padding="6,4"
                              HorizontalContentAlignment="Left"
                              HorizontalAlignment="Stretch"
                              Command="{Binding #Root.((vm:MainViewModel)DataContext).OpenRecentDocumentCommand}"
                              CommandParameter="{Binding FullPath}"
                              ToolTip.Tip="{Binding FullPath}">
                        <StackPanel Spacing="0">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding FileSizeText}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LastOpenText}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                          </StackPanel>
                          <TextBlock Text="{Binding FullPath}"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     Margin="0,1,0,0"
                                     Foreground="#999999"/>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasMoreRecentFiles}">
                  <Button Background="Transparent"
                          FontSize="12"
                          Padding="6,2"
                          Content="更多...">
                    <Button.Flyout>
                      <Flyout Placement="Bottom">
                        <ScrollViewer MaxHeight="280" Margin="0,4,0,0">
                        <ItemsControl ItemsSource="{Binding RecentFileItemsMore}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecentFileItem">
                              <Button Background="Transparent"
                                      Padding="6,4"
                                      HorizontalContentAlignment="Left"
                                      HorizontalAlignment="Stretch"
                                      Command="{Binding #Root.((vm:MainViewModel)DataContext).OpenRecentDocumentCommand}"
                                      CommandParameter="{Binding FullPath}"
                                      ToolTip.Tip="{Binding FullPath}">
                                <StackPanel Spacing="0">
                                  <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding FileSizeText}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LastOpenText}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                  </StackPanel>
                                  <TextBlock Text="{Binding FullPath}"
                                             FontSize="11"
                                             TextTrimming="CharacterEllipsis"
                                             Margin="0,1,0,0"
                                             Foreground="#999999"/>
                                </StackPanel>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                      </Flyout>
                    </Button.Flyout>
                  </Button>
                </StackPanel>
                                <TextBlock Text="最近打开的文件夹"
                           FontSize="11"
                           Margin="0,12,0,0"/>
                <ItemsControl ItemsSource="{Binding RecentFolderPathsVisible}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <Button Background="Transparent"
                              Padding="6,4"
                              HorizontalContentAlignment="Left"
                              HorizontalAlignment="Stretch"
                              Command="{Binding #Root.((vm:MainViewModel)DataContext).OpenRecentFolderCommand}"
                              CommandParameter="{Binding}"
                              ToolTip.Tip="{Binding}">
                        <StackPanel Spacing="0">
                          <TextBlock Text="{Binding Converter={x:Static conv:PathToFileNameConverter.Instance}}"
                                     FontSize="13"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding}"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     Margin="0,1,0,0"
                                     Foreground="#999999"/>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasMoreRecentFolders}">
                  <Button Background="Transparent"
                          FontSize="12"
                          Padding="6,2"
                          Content="更多...">
                    <Button.Flyout>
                      <Flyout Placement="Bottom">
                        <ScrollViewer MaxHeight="220" Margin="0,4,0,0">
                        <ItemsControl ItemsSource="{Binding RecentFolderPathsMore}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                              <Button Background="Transparent"
                                      Padding="6,4"
                                      HorizontalContentAlignment="Left"
                                      HorizontalAlignment="Stretch"
                                      Command="{Binding #Root.((vm:MainViewModel)DataContext).OpenRecentFolderCommand}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="{Binding}">
                                <StackPanel Spacing="0">
                                  <TextBlock Text="{Binding Converter={x:Static conv:PathToFileNameConverter.Instance}}"
                                             FontSize="13"
                                             TextTrimming="CharacterEllipsis"/>
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             TextTrimming="CharacterEllipsis"
                                             Margin="0,1,0,0"
                                             Foreground="#999999"/>
                                </StackPanel>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                      </Flyout>
                    </Button.Flyout>
                  </Button>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- 文档标签页（右侧上方），有文档时显示 -->
        <Border Grid.Row="0"
                IsVisible="{Binding ShowEditorView}"
                BorderThickness="0"
                Classes="tabBarBorder">
          <TabControl x:Name="DocumentTabControl"
                      ItemsSource="{Binding OpenDocuments}"
                      SelectedItem="{Binding ActiveDocument, Mode=TwoWay}"
                      Margin="4,2,0,0"
                      HorizontalAlignment="Left">
            <TabControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DocumentItem">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding IconText}"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding DisplayName}"
                             FontSize="12"
                             VerticalAlignment="Center"/>
                  <Button Classes="tab-close"
                          ToolTip.Tip="关闭"
                          Content="✕"/>
                </StackPanel>
              </DataTemplate>
            </TabControl.ItemTemplate>
          </TabControl>
        </Border>

        <!-- 编辑区 + 预览区，有文档时显示 -->
        <Grid Grid.Row="1" x:Name="ContentSplitGrid" IsVisible="{Binding ShowEditorView}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Grid x:Name="EditorPaneGrid"
                Grid.Column="0"
                RowDefinitions="*"
                Classes="editorPane">
            <ae:TextEditor x:Name="EditorTextBox"
                           Grid.Row="0"
                           x:CompileBindings="False"
                           ShowLineNumbers="True"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"
                           WordWrap="True"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="14"
                           Padding="12,8,16,8"
                           BorderThickness="0"
                           Classes="editorControl">
              <Control.ContextFlyout>
                <MenuFlyout>
                  <MenuItem Header="撤销" x:Name="EditorContextUndo"/>
                  <MenuItem Header="重做" x:Name="EditorContextRedo"/>
                  <MenuItem Header="-"/>
                  <MenuItem Header="剪切" x:Name="EditorContextCut"/>
                  <MenuItem Header="复制" x:Name="EditorContextCopy"/>
                  <MenuItem Header="粘贴" x:Name="EditorContextPaste"/>
                  <MenuItem Header="-"/>
                  <MenuItem Header="全选" x:Name="EditorContextSelectAll"/>
                  <MenuItem Header="-"/>
                  <MenuItem Header="列选择：Alt+拖拽" x:Name="EditorContextColumnSelectHint" IsEnabled="False"/>
                </MenuFlyout>
              </Control.ContextFlyout>
            </ae:TextEditor>
          </Grid>

          <!-- 编辑/预览分隔条：拖动时只显示蓝色预览线，松手后再应用布局（VS 风格） -->
          <Border x:Name="ContentSplitter"
                  Grid.Column="1"
                  Background="Transparent"
                  BorderBrush="{DynamicResource SplitterBorderBrush}"
                  BorderThickness="1,0,0,0"
                  Width="4"
                  Cursor="SizeWestEast"/>
          <Border x:Name="ContentSplitterOverlay"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Grid.Row="0"
                  Background="Transparent"
                  IsHitTestVisible="False"
                  ZIndex="10">
            <Border x:Name="ContentSplitterPreviewLine"
                    Width="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource StatusBarBackground}"
                    IsVisible="False"/>
          </Border>

          <Grid x:Name="PreviewPaneGrid"
                Grid.Column="2"
                RowDefinitions="*"
                Classes="previewPane">
            <controls:MarkdownEngineView x:Name="PreviewEngine"
                                         Grid.Row="0"
                                         Focusable="True"
                                         IsVisible="{Binding ShowMarkdownPreview}"
                                         Markdown="{Binding CurrentMarkdown}"
                                         StyleConfig="{Binding Config.Markdown}"
                                         ZoomLevel="{Binding PreviewZoomLevel}"
                                         Background="{Binding Config.Markdown.BackgroundColor, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>
            <Border Grid.Row="0"
                    IsVisible="{Binding ShowPreviewImage}"
                    Background="{Binding Config.Markdown.BackgroundColor, Converter={x:Static conv:HexToBrushConverter.Instance}}">
              <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding PreviewImagePath, Converter={x:Static conv:PathToImageConverter.Instance}}"
                       Stretch="None"/>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Grid>
      </Grid>
      <!-- 折叠箭头悬浮层：仅箭头大小，垂直居中贴滚动条左侧，不占内容区留白 -->
      <Border x:Name="SidebarCollapseStripOverlay"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch"
              Background="Transparent"
              ZIndex="100">
        <Border x:Name="SidebarCollapseButtonHitArea"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="24" Height="24"
                Background="Transparent"
                Cursor="Hand"
                ToolTip.Tip="{Binding IsSidebarCollapsed, Converter={x:Static conv:SidebarCollapseToolTipConverter.Instance}}"
                PointerPressed="SidebarCollapseStrip_OnPointerPressed"
                PointerEntered="SidebarCollapseStrip_OnPointerEntered"
                PointerExited="SidebarCollapseStrip_OnPointerExited">
          <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Path x:Name="SidebarExpandPath"
                  IsVisible="{Binding IsSidebarCollapsed}"
                  Data="M 0 0 L 6 4 L 0 8 Z"
                  Fill="{DynamicResource SidebarTextForeground}"
                  Stretch="Uniform"
                  Width="8" Height="10"/>
            <Path x:Name="SidebarCollapsePath"
                  IsVisible="{Binding ShowSidebarCollapseIcon}"
                  Data="M 6 0 L 0 4 L 6 8 Z"
                  Fill="{DynamicResource SidebarTextForeground}"
                  Stretch="Uniform"
                  Width="8" Height="10"/>
          </Panel>
        </Border>
      </Border>
    </Grid>

    <!-- 底部状态栏 -->
    <Border Grid.Row="2"
            Height="24"
            Classes="statusBar">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="8,0">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding CurrentFilePath, FallbackValue=未打开文档}"
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="480"
                     ToolTip.Tip="{Binding CurrentFilePath}"/>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <TextBlock Text="布局:"
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"/>
          <Button x:Name="LayoutModeButton"
                  Content="编辑+预览"
                  FontSize="11"
                  Padding="6,0">
            <Button.Flyout>
              <MenuFlyout Placement="Top">
                <MenuItem x:Name="LayoutBothMenuItem" Header="编辑+预览"/>
                <MenuItem x:Name="LayoutEditorOnlyMenuItem" Header="仅编辑"/>
                <MenuItem x:Name="LayoutPreviewOnlyMenuItem" Header="仅预览"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text=" | "
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"
                     VerticalAlignment="Center"/>
          <TextBlock Text="缩放:"
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"
                     VerticalAlignment="Center"/>
          <Button x:Name="ZoomLevelButton"
                  Content="{Binding ActivePaneZoomLevel, StringFormat={}{0:P0}}"
                  ToolTip.Tip="{Binding ZoomLevelToolTip}"
                  FontSize="11"
                  Foreground="{DynamicResource StatusBarForeground}"
                  Background="Transparent"
                  Padding="4,0"
                  MinWidth="32"
                  HorizontalContentAlignment="Center"
                  VerticalAlignment="Center">
            <Button.Flyout>
              <MenuFlyout Placement="Top">
                <MenuItem Header="50%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="0.5"/>
                <MenuItem Header="75%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="0.75"/>
                <MenuItem Header="90%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="0.9"/>
                <MenuItem Header="100%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.0"/>
                <MenuItem Header="125%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.25"/>
                <MenuItem Header="150%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.5"/>
                <MenuItem Header="175%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.75"/>
                <MenuItem Header="200%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="2.0"/>
                <MenuItem Header="250%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="2.5"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{Binding CaretLine, StringFormat=行 {0}}"
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"/>
          <TextBlock Text="{Binding CaretColumn, StringFormat=列 {0}}"
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"/>
          <TextBlock Text=" | "
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"/>
          <Button x:Name="EncodingButton"
                  Content="{Binding CurrentEncodingName}"
                  ToolTip.Tip="点击选择编码"
                  FontSize="11"
                  Foreground="{DynamicResource StatusBarForeground}"
                  Background="Transparent"
                  Padding="4,0"
                  MinWidth="32"
                  HorizontalContentAlignment="Center"
                  VerticalAlignment="Center">
            <Button.Flyout>
              <MenuFlyout Placement="Top">
                <MenuItem Header="UTF-8" Command="{Binding SetEncodingCommand}" CommandParameter="UTF-8"/>
                <MenuItem Header="ASCII" Command="{Binding SetEncodingCommand}" CommandParameter="ASCII"/>
                <MenuItem Header="GB18030" Command="{Binding SetEncodingCommand}" CommandParameter="GB18030"/>
                <MenuItem Header="GBK" Command="{Binding SetEncodingCommand}" CommandParameter="GBK"/>
                <MenuItem Header="GB2312" Command="{Binding SetEncodingCommand}" CommandParameter="GB2312"/>
                <MenuItem Header="UTF-16" Command="{Binding SetEncodingCommand}" CommandParameter="UTF-16"/>
                <MenuItem Header="UTF-16 BE" Command="{Binding SetEncodingCommand}" CommandParameter="UTF-16 BE"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <TextBlock Text=" | Markdown"
                     Foreground="{DynamicResource StatusBarForeground}"
                     FontSize="11"/>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</Window>
