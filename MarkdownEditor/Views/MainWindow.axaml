<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MarkdownEditor.Controls"
        xmlns:vm="clr-namespace:MarkdownEditor.ViewModels"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="MarkdownEditor.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="True"
        Title="Markdown Editor"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="32"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        Background="#1e1e1e">

  <Window.Styles>
    <!-- 通用按钮样式，偏 VSCode/Cursor 扁平风格 -->
    <Style Selector="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="#f3f3f3"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#3e3e3e"/>
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#2d2d2d"/>
    </Style>

    <!-- Tab 样式，模拟 VSCode 顶部标签 -->
    <Style Selector="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <!-- 通用 TabItem 样式：文字颜色/间距 -->
    <Style Selector="TabItem">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Normal"/>
      <Setter Property="MinHeight" Value="28"/>
    </Style>
    <!-- 控制 TabItem 内部 Border 的背景（真正看到的底色） -->
    <Style Selector="TabItem /template/ Border">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <!-- Hover 未选中标签：让底色变亮，产生“发光”感 -->
    <Style Selector="TabItem:pointerover:not(:selected) /template/ Border">
      <Setter Property="Background" Value="#3a3d41"/>
    </Style>
    <!-- 选中标签：更亮背景 + 加粗文字 -->
    <Style Selector="TabItem:selected /template/ Border">
      <Setter Property="Background" Value="#333333"/>
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="#ffffff"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <!-- 已选中的标签在 Hover 时保持选中样式，不再套用 Hover 样式 -->
    <Style Selector="TabItem:selected:pointerover /template/ Border">
      <Setter Property="Background" Value="#333333"/>
    </Style>
    <!-- 去掉 Avalonia Fluent 默认的下划线：隐藏 PART_SelectedPipe -->
    <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Height" Value="0"/>
    </Style>
    <!-- 隐藏 TabControl 默认内容区域，只保留标签头 -->
    <Style Selector="TabControl ContentPresenter#PART_SelectedContentHost">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Height" Value="0"/>
    </Style>
    <!-- 活动栏按钮选中态 -->
    <Style Selector="Button.active">
      <Setter Property="Background" Value="#252526"/>
    </Style>
    <!-- 标签页关闭按钮：默认隐藏，悬停或选中时显示 -->
    <Style Selector="TabItem Button.tab-close">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TabItem:pointerover Button.tab-close">
      <Setter Property="IsVisible" Value="True"/>
    </Style>
    <!-- 选中状态下始终显示关闭按钮 -->
    <Style Selector="TabItem:selected Button.tab-close">
      <Setter Property="IsVisible" Value="True"/>
    </Style>

    <!-- 竖向 GridSplitter：默认 1px 灰线可见，悬停/拖动时变为蓝色；整体宽度 2px -->
    <Style Selector="GridSplitter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="BorderBrush" Value="#3f3f46"/>
      <Setter Property="Width" Value="2"/>
      <Setter Property="Cursor" Value="SizeWestEast"/>
    </Style>
    <Style Selector="GridSplitter:pointerover">
      <!-- 悬停/拖动时只绘制 1px 蓝线，尽量纤细 -->
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="BorderBrush" Value="#007acc"/>
    </Style>
    <Style Selector="GridSplitter:pressed">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="BorderBrush" Value="#007acc"/>
    </Style>
  </Window.Styles>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
  </Window.KeyBindings>

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- 顶部：标题 + 菜单（VSCode 风格标题栏，可拖动、双击最大化，支持 Windows 停靠） -->
    <Border Grid.Row="0" Background="#252526" Padding="8,0">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto" Height="32">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,12,0">
          <Ellipse Width="14" Height="14" Fill="#007acc" VerticalAlignment="Center"/>
          <TextBlock Text="Markdown Editor" Margin="6,0,0,0"
                     VerticalAlignment="Center"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#f3f3f3"/>
        </StackPanel>

        <Menu Grid.Column="1" VerticalAlignment="Stretch">
          <MenuItem Header="文件(_F)">
            <MenuItem Header="新建" x:Name="NewFileMenuItem"/>
            <MenuItem Header="打开文件夹,,," x:Name="OpenFolderMenuItem"/>
            <MenuItem Header="打开文件..." x:Name="OpenFileMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="保存" x:Name="SaveMenuItem"/>
            <MenuItem Header="另存为..." x:Name="SaveAsMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="导出" x:Name="ExportMenu">
              <MenuItem Header="导出为 HTML..." x:Name="ExportHtmlMenuItem"/>
              <MenuItem Header="导出为 PDF..." x:Name="ExportPdfMenuItem"/>
              <MenuItem Header="导出为长图 (PNG)..." x:Name="ExportPngMenuItem"/>
              <MenuItem Header="导出为 Word (DOCX)..." x:Name="ExportDocxMenuItem"/>
            </MenuItem>
            <MenuItem Header="-"/>
            <MenuItem Header="关闭当前文档" x:Name="CloseEditorMenuItem"/>
            <MenuItem Header="-"/>
            <MenuItem Header="退出" x:Name="ExitMenuItem"/>
          </MenuItem>
        </Menu>

        <Border Grid.Column="2"
                x:Name="TitleDragArea"
                Background="Transparent">
          <TextBlock Text="{Binding CurrentFileName}"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="320"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="13"
                     Foreground="#b0b0b0"
                     IsHitTestVisible="False"/>
        </Border>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="8"/>
      </Grid>
    </Border>

    <!-- 主体：侧栏（顶部活动栏 + 内容） + 右侧内容区（标签页在右侧上方） -->
    <Grid Grid.Row="1" x:Name="MainGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" MinWidth="180" MaxWidth="420"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- 侧栏：顶部为活动栏（水平），下方为 资源管理器 / 搜索 / Git -->
      <Border Grid.Column="0"
              x:Name="SidebarBorder"
              Background="#252526"
              BorderBrush="#3f3f46"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <!-- 顶部活动栏（水平，与文档标签栏高度统一：28px） -->
          <Border Grid.Row="0"
                  Background="#333333"
                  BorderBrush="#3f3f46"
                  BorderThickness="0,0,0,1"
                  Padding="2,2"
                  MinHeight="32">
            <StackPanel Orientation="Horizontal" Spacing="2"
                        VerticalAlignment="Center">
              <Button x:Name="ActivityExplorerButton"
                      ToolTip.Tip="资源管理器"
                      Width="32" Height="28"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <Image Source="avares://MarkdownEditor/asserts/file_explorer.png"
                       Width="12" Height="12"/>
              </Button>
              <Button x:Name="ActivitySearchButton"
                      ToolTip.Tip="搜索"
                      Width="32" Height="28"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <Image Source="avares://MarkdownEditor/asserts/search.png"
                       Width="12" Height="12"/>
              </Button>
              <Button x:Name="ActivityGitButton"
                      ToolTip.Tip="源代码管理 (Git)"
                      Width="32" Height="28"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <Image Source="avares://MarkdownEditor/asserts/version_control.png"
                       Width="12" Height="12"/>
              </Button>
              <Button x:Name="ActivitySettingsButton"
                      ToolTip.Tip="设置"
                      Width="32" Height="28"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Content="⚙"
                      FontSize="14"/>
            </StackPanel>
          </Border>

          <Grid Grid.Row="1">
            <!-- 资源管理器 -->
            <Grid IsVisible="{Binding ShowExplorerPane}" RowDefinitions="Auto,*">
              <!-- 根目录行：路径/名称 + 刷新 -->
              <Border Grid.Row="0" Background="#2d2d30" Padding="6,4" BorderBrush="#3f3f46" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <TextBlock Text="{Binding DocumentFolder}"
                             FontSize="11"
                             Foreground="#cccccc"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             MaxWidth="170"
                             ToolTip.Tip="{Binding DocumentFolder}"/>
                  <Button x:Name="FileTreeRefreshRootBtn"
                          ToolTip.Tip="刷新"
                          Width="22" Height="22"
                          Padding="0"
                          FontSize="11"
                          Content="↻"/>
                </StackPanel>
              </Border>
            <Grid Grid.Row="1" RowDefinitions="*">
              <TreeView Grid.Row="0"
                      x:Name="FileTreeView"
                      Classes="NoIndentTree"
                      ItemsSource="{Binding FileTreeRoot}"
                      SelectedItem="{Binding SelectedTreeNode}"
                      Margin="-24,0,4,4"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="#cccccc"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <TreeView.ContextFlyout>
                  <MenuFlyout>
                    <MenuItem Header="复制路径" x:Name="FileTreeCopyPathItem"/>
                    <MenuItem Header="重命名" x:Name="FileTreeRenameItem"/>
                    <MenuItem Header="新建文件" x:Name="FileTreeNewFileItem"/>
                    <MenuItem Header="新建文件夹" x:Name="FileTreeNewFolderItem"/>
                    <MenuItem Header="删除" x:Name="FileTreeDeleteItem"/>
                  </MenuFlyout>
                </TreeView.ContextFlyout>
              <TreeView.Styles>
                <!-- 节点展开状态与 ViewModel 同步 -->
                <Style Selector="TreeViewItem" x:DataType="vm:FileTreeNode">
                  <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                  <Setter Property="Padding" Value="0"/>
                  <!-- 行高更紧凑 -->
                  <Setter Property="MinHeight" Value="18"/>
                </Style>
                <!-- 隐藏内置展开箭头，改用自定义图标 -->
                <Style Selector="TreeViewItem /template/ ToggleButton">
                  <Setter Property="IsVisible" Value="False"/>
                  <Setter Property="Width" Value="0"/>
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="Foreground" Value="#cccccc"/>
                  <Setter Property="MinWidth" Value="0"/>
                  <Setter Property="Margin" Value="0"/>
                  <Setter Property="Padding" Value="0"/>
                </Style>
                <!-- 行级背景：直接作用在 TreeViewItem 上，整行（含缩进列）统一着色 -->
                <Style Selector="TreeViewItem:selected">
                  <Setter Property="Background" Value="#094771"/>
                  <!-- 选中文字用略带灰的浅色而不是纯白 -->
                  <Setter Property="Foreground" Value="#f0f0f0"/>
                </Style>
                <Style Selector="TreeViewItem:pointerover">
                  <Setter Property="Background" Value="#2a2d2e"/>
                </Style>
                <!-- 树内箭头按钮不单独高亮，保持透明，由行高亮统一体现 -->
                <Style Selector="TreeView TreeViewItem Button">
                  <Setter Property="Background" Value="Transparent"/>
                  <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="TreeView TreeViewItem Button:pointerover">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="TreeView TreeViewItem Button:pressed">
                  <Setter Property="Background" Value="Transparent"/>
                </Style>
              </TreeView.Styles>
              <TreeView.ItemTemplate>
                <TreeDataTemplate x:DataType="vm:FileTreeNode"
                                  ItemsSource="{Binding Children}">
                  <StackPanel Orientation="Horizontal"
                              Spacing="1"
                              Margin="2,0,2,0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              ToolTip.Tip="{Binding FullPath}">
                    <!-- 固定宽度的箭头列：始终占位，避免文件与文件夹在水平方向抖动 -->
                    <Grid Width="12"
                          Margin="0,0,2,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                      <!-- 折叠状态箭头：向右 -->
                      <Image Source="avares://MarkdownEditor/asserts/folder_arrow_right_dark.png"
                             Width="10"
                             Height="10"
                             VerticalAlignment="Center"
                             IsVisible="{Binding ShowRightArrow}"/>
                      <!-- 展开状态箭头：向下 -->
                      <Image Source="avares://MarkdownEditor/asserts/folder_arrow_down_dark.png"
                             Width="10"
                             Height="10"
                             VerticalAlignment="Center"
                             IsVisible="{Binding ShowDownArrow}"/>
                    </Grid>

                    <!-- 图标列：固定宽度，文件显示图标，文件夹为空字符串也占位 -->
                    <TextBlock Text="{Binding IconText}"
                               Width="12"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Foreground="#cccccc"/>

                    <!-- 名称：非重命名时显示标签 -->
                    <TextBlock Text="{Binding DisplayName}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#dddddd"
                               TextTrimming="CharacterEllipsis"
                               IsVisible="{Binding ShowLabel}"/>
                    <!-- 重命名时显示输入框，就地编辑 -->
                    <TextBox Text="{Binding EditName, Mode=TwoWay}"
                             IsVisible="{Binding IsRenaming}"
                             MinWidth="80"
                             Height="22"
                             FontSize="12"
                             Padding="4,0,4,0"
                             VerticalContentAlignment="Center"
                             Background="#3c3c3c"
                             Foreground="#f3f3f3"
                             BorderThickness="1"
                             LostFocus="TreeItemRename_OnLostFocus"
                             KeyDown="TreeItemRename_OnKeyDown"/>
                  </StackPanel>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
            </Grid>
          </Grid>

          <!-- 搜索（跨文档，点击结果定位到行） -->
          <Border x:Name="SearchPaneBorder"
                  IsVisible="{Binding ShowSearchPane}"
                  Background="#252526"
                  Padding="8,6">
            <StackPanel Spacing="4">
              <TextBlock Text="搜索" FontWeight="SemiBold" Foreground="#cccccc" FontSize="12"/>
              <TextBox x:Name="SearchQueryTextBox"
                       Text="{Binding SearchQuery}"
                       Watermark="搜索文档..."
                       Background="#3c3c3c"
                       Foreground="#f3f3f3"
                       BorderBrush="#3f3f46"
                       CaretBrush="#ffffff"
                       FontSize="12"
                       Padding="6,4"/>
              <TextBlock Text="结果（按文件分组，点击行定位）"
                         Foreground="#858585"
                         FontSize="10"/>
              <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SearchResultGroupsControl"
                              ItemsSource="{Binding SearchResultGroups}"
                              Background="Transparent"
                              FontFamily="Consolas,Segoe UI,sans-serif">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchResultGroup">
                      <StackPanel Margin="0,1">
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="0,3,8,3"
                                HorizontalContentAlignment="Left"
                                Click="SearchResultFileHeader_OnClick">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="14" Height="14"
                                    VerticalAlignment="Center"
                                    Background="Transparent">
                              <TextBlock Text="{Binding ExpandArrow}"
                                         FontSize="11"
                                         FontFamily="Segoe UI Symbol,Consolas,sans-serif"
                                         Foreground="#858585"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Orientation="Vertical" Spacing="0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding FileName}"
                                         FontSize="12"
                                         Foreground="#cccccc"
                                         TextTrimming="CharacterEllipsis"/>
                              <TextBlock Text="{Binding FolderPath}"
                                         FontSize="10"
                                         Foreground="#6e6e6e"
                                         TextTrimming="CharacterEllipsis"
                                         IsVisible="{Binding HasFolderPath}"/>
                            </StackPanel>
                          </StackPanel>
                        </Button>
                        <ItemsControl ItemsSource="{Binding Items}"
                                      IsVisible="{Binding IsExpanded}"
                                      Margin="12,0,0,4">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchResultItem">
                              <Button Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0,2,0,2"
                                      HorizontalContentAlignment="Left"
                                      Click="SearchResultLine_OnClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <TextBlock Text="{Binding LineNumber, StringFormat=L{0}}"
                                             FontSize="11"
                                             Foreground="#569cd6"
                                             VerticalAlignment="Center"
                                             MinWidth="28"
                                             FontFamily="Consolas,Segoe UI,sans-serif"/>
                                  <TextBlock Text="{Binding LinePreview}"
                                             FontSize="11"
                                             Foreground="#d4d4d4"
                                             VerticalAlignment="Center"
                                             TextTrimming="CharacterEllipsis"
                                             FontFamily="Consolas,Segoe UI,sans-serif"/>
                                </StackPanel>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>

          <!-- Git -->
          <Border IsVisible="{Binding ShowGitPane}"
                  Background="#252526"
                  Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="源代码管理" FontWeight="Bold" Foreground="#cccccc"/>
              <TextBlock Text="Git 功能占位，可后续接入。"
                         Foreground="#858585"
                         FontSize="11"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <!-- 设置 -->
          <ScrollViewer IsVisible="{Binding ShowSettingsPane}"
                        Background="#252526"
                        Padding="12">
            <StackPanel Spacing="12">
              <TextBlock Text="设置" FontWeight="Bold" Foreground="#cccccc"/>
              <TextBlock Text="界面" Foreground="#858585" FontSize="11"/>
              <StackPanel Spacing="6">
                <TextBlock Text="代码块背景" Foreground="#d4d4d4" FontSize="11"/>
                <TextBox Text="{Binding Config.Markdown.CodeBlockBackground, Mode=TwoWay}"
                         Background="#3c3c3c"
                         Foreground="#f3f3f3"
                         BorderBrush="#3f3f46"/>
                <TextBlock Text="正文字体" Foreground="#d4d4d4" FontSize="11"/>
                <TextBox Text="{Binding Config.Markdown.BodyFontFamily, Mode=TwoWay}"
                         Background="#3c3c3c"
                         Foreground="#f3f3f3"
                         BorderBrush="#3f3f46"/>
                <TextBlock Text="链接颜色" Foreground="#d4d4d4" FontSize="11"/>
                <TextBox Text="{Binding Config.Markdown.LinkColor, Mode=TwoWay}"
                         Background="#3c3c3c"
                         Foreground="#f3f3f3"
                         BorderBrush="#3f3f46"/>
              </StackPanel>
              <Button x:Name="SettingsSaveButton"
                      Content="保存配置"
                      HorizontalAlignment="Left"/>
            </StackPanel>
          </ScrollViewer>
          </Grid>
        </Grid>
      </Border>

      <!-- 侧栏分隔条：拖动时只显示蓝色预览线，松手后再应用布局（VS 风格） -->
      <Border x:Name="SidebarSplitter"
              Grid.Column="1"
              Background="Transparent"
              BorderBrush="#3f3f46"
              BorderThickness="1,0,0,0"
              Width="4"
              Cursor="SizeWestEast"/>
      <!-- 侧栏分隔条拖动时的蓝色预览线（覆盖在 MainGrid 上，仅拖动时显示） -->
      <Border x:Name="SidebarSplitterOverlay"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Grid.Row="0"
              Background="Transparent"
              IsHitTestVisible="False"
              ZIndex="10">
        <Border x:Name="SidebarSplitterPreviewLine"
                Width="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Background="#007acc"
                IsVisible="False"/>
      </Border>

      <!-- 右侧内容区：欢迎页 或 文档标签页+编辑+预览 -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*">
        <!-- 欢迎页：无打开文档时显示，VSCode 风格最近打开 -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowWelcomeView}"
                Background="#1e1e1e"
                Padding="24,32">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" MaxWidth="520" HorizontalAlignment="Left">
              <TextBlock Text="打开最近"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#cccccc"/>
              <StackPanel Spacing="4">
                <TextBlock Text="最近打开的文档（按打开时间排序）"
                           FontSize="11"
                           Foreground="#858585"/>
                <ItemsControl ItemsSource="{Binding RecentFileItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RecentFileItem">
                      <Button Background="Transparent"
                              Foreground="#cccccc"
                              FontSize="13"
                              Padding="8,6"
                              HorizontalContentAlignment="Left"
                              HorizontalAlignment="Stretch"
                              Command="{Binding #Root.((vm:MainViewModel)DataContext).OpenRecentDocumentCommand}"
                              CommandParameter="{Binding FullPath}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                          <TextBlock Text="{Binding DisplayName}"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center"
                                     ToolTip.Tip="{Binding FullPath}"/>
                          <TextBlock Text="{Binding FileSizeText}"
                                     FontSize="11"
                                     Foreground="#858585"
                                     VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding LastOpenText}"
                                     FontSize="11"
                                     Foreground="#6e6e6e"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="最近打开的文件夹"
                           FontSize="11"
                           Foreground="#858585"
                           Margin="0,12,0,0"/>
                <ItemsControl ItemsSource="{Binding RecentFolderPaths}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <Button Background="Transparent"
                              Foreground="#cccccc"
                              FontSize="13"
                              Padding="8,6"
                              HorizontalContentAlignment="Left"
                              HorizontalAlignment="Stretch"
                              Command="{Binding #Root.((vm:MainViewModel)DataContext).OpenRecentFolderCommand}"
                              CommandParameter="{Binding}">
                        <Button.Content>
                          <TextBlock Text="{Binding}"
                                     TextTrimming="CharacterEllipsis"
                                     ToolTip.Tip="{Binding}"/>
                        </Button.Content>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button x:Name="WelcomeOpenFileButton"
                        Content="打开文件..."
                        FontSize="12"
                        Padding="12,6"/>
                <Button x:Name="WelcomeOpenFolderButton"
                        Content="打开文件夹..."
                        FontSize="12"
                        Padding="12,6"/>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- 文档标签页（右侧上方），有文档时显示 -->
        <Border Grid.Row="0"
                IsVisible="{Binding ShowEditorView}"
                Background="#252526"
                BorderBrush="#3f3f46"
                BorderThickness="0">
          <TabControl x:Name="DocumentTabControl"
                      ItemsSource="{Binding OpenDocuments}"
                      SelectedItem="{Binding ActiveDocument, Mode=TwoWay}"
                      Margin="4,2,0,0"
                      HorizontalAlignment="Left">
            <TabControl.ItemTemplate>
              <DataTemplate x:DataType="vm:DocumentItem">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding IconText}"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Margin="0,0,4,0"/>
                  <TextBlock Text="{Binding DisplayName}"
                             FontSize="12"
                             VerticalAlignment="Center"/>
                  <Button Classes="tab-close"
                          ToolTip.Tip="关闭"
                          Command="{Binding #Root.((vm:MainViewModel)DataContext).CloseDocumentCommand}"
                          CommandParameter="{Binding}"
                          Content="✕"/>
                </StackPanel>
              </DataTemplate>
            </TabControl.ItemTemplate>
          </TabControl>
        </Border>

        <!-- 编辑区 + 预览区，有文档时显示 -->
        <Grid Grid.Row="1" x:Name="ContentSplitGrid" IsVisible="{Binding ShowEditorView}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Grid x:Name="EditorPaneGrid"
                Grid.Column="0"
                RowDefinitions="*">
            <ae:TextEditor x:Name="EditorTextBox"
                           Grid.Row="0"
                           x:CompileBindings="False"
                           ShowLineNumbers="True"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"
                           WordWrap="True"
                           FontFamily="Consolas,Cascadia Code,monospace"
                           FontSize="14"
                           Padding="12,8,0,8"
                           BorderThickness="0"
                           Background="#1e1e1e"
                           Foreground="#d4d4d4">
              <Control.ContextFlyout>
                <MenuFlyout>
                  <MenuItem Header="撤销" x:Name="EditorContextUndo"/>
                  <MenuItem Header="重做" x:Name="EditorContextRedo"/>
                  <MenuItem Header="-"/>
                  <MenuItem Header="剪切" x:Name="EditorContextCut"/>
                  <MenuItem Header="复制" x:Name="EditorContextCopy"/>
                  <MenuItem Header="粘贴" x:Name="EditorContextPaste"/>
                  <MenuItem Header="-"/>
                  <MenuItem Header="全选" x:Name="EditorContextSelectAll"/>
                  <MenuItem Header="-"/>
                  <MenuItem Header="列选择：Alt+拖拽" x:Name="EditorContextColumnSelectHint" IsEnabled="False"/>
                </MenuFlyout>
              </Control.ContextFlyout>
            </ae:TextEditor>
          </Grid>

          <!-- 编辑/预览分隔条：拖动时只显示蓝色预览线，松手后再应用布局（VS 风格） -->
          <Border x:Name="ContentSplitter"
                  Grid.Column="1"
                  Background="Transparent"
                  BorderBrush="#3f3f46"
                  BorderThickness="1,0,0,0"
                  Width="4"
                  Cursor="SizeWestEast"/>
          <!-- 编辑/预览分隔条拖动时的蓝色预览线 -->
          <Border x:Name="ContentSplitterOverlay"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Grid.Row="0"
                  Background="Transparent"
                  IsHitTestVisible="False"
                  ZIndex="10">
            <Border x:Name="ContentSplitterPreviewLine"
                    Width="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Background="#007acc"
                    IsVisible="False"/>
          </Border>

          <Grid x:Name="PreviewPaneGrid"
                Grid.Column="2"
                RowDefinitions="*"
                Background="#1e1e1e">
            <controls:MarkdownEngineView x:Name="PreviewEngine"
                                         Grid.Row="0"
                                         Focusable="True"
                                         Markdown="{Binding CurrentMarkdown}"
                                         StyleConfig="{Binding Config.Markdown}"
                                         ZoomLevel="{Binding PreviewZoomLevel}"/>
          </Grid>
        </Grid>
      </Grid>
    </Grid>

    <!-- 底部状态栏 -->
    <Border Grid.Row="2"
            Background="#007acc"
            Height="24">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="8,0">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentFilePath, FallbackValue=未打开文档}"
                     Foreground="White"
                     FontSize="11"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="480"
                             ToolTip.Tip="{Binding CurrentFilePath}"/>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <TextBlock Text="布局:"
                     Foreground="White"
                     FontSize="10"/>
          <Button x:Name="LayoutBothButton"
                  Content="编辑+预览"
                  FontSize="10"
                  Padding="6,0"/>
          <Button x:Name="LayoutEditorOnlyButton"
                  Content="仅编辑"
                  FontSize="10"
                  Padding="6,0"/>
          <Button x:Name="LayoutPreviewOnlyButton"
                  Content="仅预览"
                  FontSize="10"
                  Padding="6,0"/>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text=" | "
                     Foreground="White"
                     FontSize="10"
                     VerticalAlignment="Center"/>
          <TextBlock Text="缩放:"
                     Foreground="White"
                     FontSize="10"
                     VerticalAlignment="Center"/>
          <Button x:Name="ZoomLevelButton"
                  Content="{Binding ActivePaneZoomLevel, StringFormat={}{0:P0}}"
                  ToolTip.Tip="点击选择缩放比例"
                  FontSize="10"
                  Foreground="White"
                  Background="Transparent"
                  Padding="4,0"
                  MinWidth="32"
                  HorizontalContentAlignment="Center"
                  VerticalAlignment="Center">
            <Button.Flyout>
              <MenuFlyout Placement="Top">
                <MenuItem Header="50%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="0.5"/>
                <MenuItem Header="75%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="0.75"/>
                <MenuItem Header="90%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="0.9"/>
                <MenuItem Header="100%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.0"/>
                <MenuItem Header="125%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.25"/>
                <MenuItem Header="150%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.5"/>
                <MenuItem Header="175%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="1.75"/>
                <MenuItem Header="200%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="2.0"/>
                <MenuItem Header="250%" Command="{Binding SetActivePaneZoomCommand}" CommandParameter="2.5"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{Binding CaretLine, StringFormat=行 {0}}"
                     Foreground="White"
                     FontSize="10"/>
          <TextBlock Text="{Binding CaretColumn, StringFormat=列 {0}}"
                     Foreground="White"
                     FontSize="10"/>
          <TextBlock Text=" | "
                     Foreground="White"
                     FontSize="10"/>
          <Button x:Name="EncodingButton"
                  Content="{Binding CurrentEncodingName}"
                  ToolTip.Tip="点击选择编码"
                  FontSize="10"
                  Foreground="White"
                  Background="Transparent"
                  Padding="4,0"
                  MinWidth="32"
                  HorizontalContentAlignment="Center"
                  VerticalAlignment="Center">
            <Button.Flyout>
              <MenuFlyout Placement="Top">
                <MenuItem Header="UTF-8" Command="{Binding SetEncodingCommand}" CommandParameter="UTF-8"/>
                <MenuItem Header="ASCII" Command="{Binding SetEncodingCommand}" CommandParameter="ASCII"/>
                <MenuItem Header="GBK" Command="{Binding SetEncodingCommand}" CommandParameter="GBK"/>
                <MenuItem Header="GB2312" Command="{Binding SetEncodingCommand}" CommandParameter="GB2312"/>
                <MenuItem Header="UTF-16" Command="{Binding SetEncodingCommand}" CommandParameter="UTF-16"/>
                <MenuItem Header="UTF-16 BE" Command="{Binding SetEncodingCommand}" CommandParameter="UTF-16 BE"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <TextBlock Text=" | Markdown"
                     Foreground="White"
                     FontSize="10"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 文件在外部被修改时显示的提示条（浮在内容区上方，不占用文件） -->
    <Border x:Name="FileChangedBar"
            Grid.Row="1"
            IsVisible="{Binding FileChangedExternally}"
            Background="#3e3e3e"
            Padding="12,6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Margin="0,36,0,0"
            ZIndex="100">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="文件已在外部修改。"
                   Foreground="#d4d4d4"
                   VerticalAlignment="Center"/>
        <Button Content="重新加载"
                Command="{Binding ReloadFromDiskCommand}"
                Padding="8,2"/>
        <Button Content="忽略"
                Command="{Binding DismissFileChangedCommand}"
                Padding="8,2"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
